{
  "name": "@leptest/eslint-config-leptest",
  "version": "8.4.0",
  "description": "Eslint shareable config",
  "main": "index.js",
  "scripts": {
    "test": "node examples/test-rules.js",
    "eslint": "eslint .",
    "eslint-fix": "eslint --fix .",
    "show-config": "node show-config.js",
    "show-config:json": "node show-config.js --json",
    "show-config:normalize": "node show-config.js --normalize"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leptest/eslint-config-leptest.git"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "leptest"
  ],
  "author": "Daniel Chapman",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/leptest/eslint-config-leptest/issues"
  },
  "homepage": "https://github.com/leptest/eslint-config-leptest#readme",
  "dependencies": {
    "@eslint/js": "9.39.4",
    "@stylistic/eslint-plugin": "5.10.0",
    "eslint": "9.39.4",
    "eslint-plugin-compat": "7.0.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "16.2.0",
    "typescript-eslint": "8.58.2"
  },
  "browserslist": [
    "defaults",
    "cover 91%",
    "not op_mini all",
    "not kaios 2.5",
    "not and_qq 13.1",
    "not dead",
    "edge > 1"
  ]
}
